# Supabase – öffentliche Werte (dürfen im Client-Bundle landen).
# Lokal: diese Datei nach .env.local kopieren und echte Werte eintragen.
# CI (GitHub Pages): als Repository Variables hinterlegen und in deploy.yml injizieren.
#
# Zu finden im Supabase-Dashboard unter Project Settings → API.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-PUBLIC-ANON-KEY

# Impressum / Datenschutz – Betreiber-Kontaktdaten.
# NICHT ins Repo committen (echte Werte in .env.local bzw. GitHub → Settings →
# Secrets and variables → Actions → Variables). Hinweis: Auf der Seite sind sie
# öffentlich sichtbar (Impressumspflicht) – die Vars halten sie nur aus dem Repo.
VITE_LEGAL_NAME=Vorname Nachname
VITE_LEGAL_STREET=Straße 1
VITE_LEGAL_CITY=12345 Stadt
VITE_LEGAL_EMAIL=kontakt@deine-domain.de
VITE_LEGAL_PHONE=
